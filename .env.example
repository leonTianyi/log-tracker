# Copy this file to `.env` and set your real values. `.env` is gitignored, so
# nothing here reaches the repo.
#
# The two CSV columns that hold the S3 paths. Set these to your real header
# names. If left unset, the app uses harmless placeholders that work with the
# sample data.
PRIMARY_COLUMN=s3-bucket-1
MIRROR_COLUMN=s3-bucket-2
